# KnowThyHealth backend — environment variables
# Copy to ".env" and fill in real values. Never commit .env.

# Anthropic Claude API key (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search API key (https://app.tavily.com → API Keys)
TAVILY_API_KEY=tvly-...

# Allowed frontend origin for CORS. Dev default is Vite's port.
# In production set this to the exact deployed frontend URL.
CORS_ORIGIN=http://localhost:5173

# HTTP port the API listens on.
PORT=3000

# production | development
NODE_ENV=development
